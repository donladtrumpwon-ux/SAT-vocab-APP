                    <div style={{ fontSize: 36, fontWeight: 800 }}>{mistakes[revIdx].word}</div>
                    <div style={{ color: "#ffffff44", fontSize: 13, marginTop: 10 }}>tap to see definition</div>
                  </div>
                ) : (
                  <div>
                    <div style={{ color: "#f59e0b", fontSize: 11, textTransform: "uppercase", letterSpacing: "0.06em", marginBottom: 8 }}>Definition</div>
                    <div style={{ fontSize: 20, fontWeight: 700, marginBottom: 12 }}>{mistakes[revIdx].meaning}</div>
                    <div style={{ color: "#ffffff55", fontSize: 13, fontStyle: "italic" }}>"{mistakes[revIdx].example}"</div>
                  </div>
                )}
              </div>
            </div>

            <div style={{ display: "flex", gap: 10, marginBottom: 24 }}>
              <button onClick={() => { setRevIdx(i => Math.max(0, i - 1)); setFlipped(false); }}
                disabled={revIdx === 0}
                style={{ flex: 1, padding: "11px", background: "#ffffff08", border: "1px solid #ffffff15", color: revIdx === 0 ? "#ffffff33" : "#fff", borderRadius: 10, cursor: revIdx === 0 ? "default" : "pointer" }}>
                ← Prev
              </button>
              <button onClick={() => {
                const toRemove = mistakes[revIdx].word;
                setState(s => ({ ...s, room: { ...s.room, mistakes: s.room.mistakes.filter(m => m.word !== toRemove) } }));
                setRevIdx(i => Math.max(0, i - 1));
                setFlipped(false);
              }} style={{ flex: 2, padding: "11px", background: "#10b98122", border: "1px solid #10b98133", color: "#34d399", borderRadius: 10, cursor: "pointer", fontWeight: 700 }}>
                ✓ Got it!
              </button>
              <button onClick={() => { setRevIdx(i => Math.min(mistakes.length - 1, i + 1)); setFlipped(false); }}
                disabled={revIdx === mistakes.length - 1}
                style={{ flex: 1, padding: "11px", background: "#ffffff08", border: "1px solid #ffffff15", color: revIdx === mistakes.length - 1 ? "#ffffff33" : "#fff", borderRadius: 10, cursor: revIdx === mistakes.length - 1 ? "default" : "pointer" }}>
                Next →
              </button>
            </div>

            {/* Mistake list */}
            <div style={{ color: "#ffffff55", fontSize: 11, textTransform: "uppercase", letterSpacing: "0.06em", marginBottom: 10 }}>All mistakes</div>
            <div style={{ display: "flex", flexDirection: "column", gap: 6 }}>
              {mistakes.map((m, i) => (
                <button key={m.word} onClick={() => { setRevIdx(i); setFlipped(false); }} style={{
                  background: i === revIdx ? "#ef444411" : "#ffffff06",
                  border: `1px solid ${i === revIdx ? "#ef444433" : "#ffffff10"}`,
                  borderRadius: 10, padding: "12px 16px", textAlign: "left", cursor: "pointer",
                  display: "flex", justifyContent: "space-between", alignItems: "center",
                }}>
                  <span style={{ fontWeight: 700, color: "#fff" }}>{m.word}</span>
                  <span style={{ color: "#ffffff44", fontSize: 12 }}>{m.type}</span>
                </button>
              ))}
            </div>
          </>
        )}
      </div>
    </div>
  );
}

function RevisionScreen({ state, setState }) {
  const learned = state.room.learnedWordIndices.map(i => SAT_WORDS[i]).filter(Boolean);
  const [quizWords] = useState(() => shuffle(learned).slice(0, Math.min(10, learned.length)));
  const [qIdx, setQIdx] = useState(0);
  const [score, setScore] = useState(0);
  const [answered, setAnswered] = useState(null);
  const [done, setDone] = useState(false);
  const [showAns, setShowAns] = useState(false);
  const questions = quizWords.map(w => genQuizQuestion(w, SAT_WORDS));

  function submit(ans) {
    if (answered !== null) return;
    const q = questions[qIdx];
    const correct = q.type === "fill" ? ans.trim().toLowerCase() === q.answer.toLowerCase() : ans === q.answer;
    setAnswered(ans);
    setShowAns(true);
    if (correct) setScore(s => s + 1);
    setTimeout(() => {
      if (qIdx >= questions.length - 1) setDone(true);
      else { setQIdx(i => i + 1); setAnswered(null); setShowAns(false); }
    }, 1500);
  }

  if (learned.length < 4) return (
    <div style={{ minHeight: "100vh", background: "#0a0a0f", fontFamily: "'Syne', sans-serif", color: "#fff", display: "flex", alignItems: "center", justifyContent: "center" }}>
      <div style={{ textAlign: "center" }}>
        <div style={{ fontSize: 56 }}>📚</div>
        <div style={{ fontSize: 18, fontWeight: 700, marginTop: 12 }}>Learn more words first!</div>
        <div style={{ color: "#ffffff55", marginTop: 4 }}>You need at least 4 learned words for revision.</div>
        <button onClick={() => setState(s => ({ ...s, screen: "home" }))} style={{ marginTop: 20, padding: "10px 24px", borderRadius: 8, background: "#ffffff10", border: "1px solid #ffffff20", color: "#fff", cursor: "pointer" }}>← Home</button>
      </div>
    </div>
  );

  if (done) return (
    <div style={{ minHeight: "100vh", background: "#0a0a0f", fontFamily: "'Syne', sans-serif", color: "#fff", display: "flex", alignItems: "center", justifyContent: "center" }}>
      <div style={{ textAlign: "center" }}>
        <div style={{ fontSize: 56 }}>{score >= questions.length * 0.8 ? "🌟" : score >= questions.length * 0.5 ? "👍" : "💪"}</div>
        <h2 style={{ fontSize: 28, fontWeight: 800, marginBottom: 4 }}>Revision Complete!</h2>
        <div style={{ fontSize: 48, fontWeight: 800, color: "#10b981" }}>{score}/{questions.length}</div>
        <div style={{ color: "#ffffff55", marginTop: 4 }}>{Math.round((score / questions.length) * 100)}% accuracy</div>
        <button onClick={() => setState(s => ({ ...s, screen: "home" }))} style={{ marginTop: 20, padding: "12px 28px", borderRadius: 10, background: "linear-gradient(135deg, #10b981, #059669)", border: "none", color: "#fff", fontWeight: 700, cursor: "pointer" }}>Back to Home</button>
      </div>
    </div>
  );

  const q = questions[qIdx];
  const [fillVal, setFillVal] = useState("");

  return (
    <div style={{ minHeight: "100vh", background: "#0a0a0f", fontFamily: "'Syne', sans-serif", color: "#fff" }}>
      <div style={{ maxWidth: 600, margin: "0 auto", padding: 20 }}>
        <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 20 }}>
          <button onClick={() => setState(s => ({ ...s, screen: "home" }))}
            style={{ background: "#ffffff10", border: "1px solid #ffffff20", color: "#fff", borderRadius: 8, padding: "8px 14px", cursor: "pointer" }}>
            ← Back
          </button>
          <h2 style={{ margin: 0, fontSize: 20, fontWeight: 700 }}>Revision Mode 🔁</h2>
        </div>
        <div style={{ color: "#ffffff55", fontSize: 12, marginBottom: 4 }}>Q {qIdx + 1} of {questions.length} · Score: {score}</div>
        <XPBar current={qIdx} max={questions.length} color="#10b981" />
        <div style={{ background: "#ffffff08", border: "1px solid #ffffff15", borderRadius: 16, padding: 24, margin: "16px 0" }}>
          <Badge text="Revision" color="#10b981" />
          <div style={{ fontSize: 17, fontWeight: 600, marginTop: 14, lineHeight: 1.5 }}>{q.prompt}</div>
        </div>
        {q.type === "fill" ? (
          <div>
            <input value={fillVal} onChange={e => setFillVal(e.target.value)}
              onKeyDown={e => e.key === "Enter" && submit(fillVal)}
              disabled={answered !== null} placeholder="Type the word..."
              style={{ width: "100%", padding: "12px 16px", background: "#ffffff0c", border: "1px solid #ffffff25", borderRadius: 10, color: "#fff", fontSize: 15, outline: "none", boxSizing: "border-box", fontFamily: "inherit", marginBottom: 10 }} />
            {answered === null && <button onClick={() => submit(fillVal)} style={{ width: "100%", padding: "12px", borderRadius: 10, background: "linear-gradient(135deg, #10b981, #059669)", border: "none", color: "#fff", fontWeight: 700, cursor: "pointer" }}>Submit</button>}
          </div>
        ) : (
          <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
            {q.options.map((opt, i) => {
              let bg = "#ffffff08", border = "#ffffff15", col = "#fff";
              if (showAns) {
                if (opt === q.answer) { bg = "#10b98122"; border = "#10b98155"; col = "#34d399"; }
                else if (opt === answered) { bg = "#ef444422"; border = "#ef444455"; col = "#f87171"; }
              }
              return (
                <button key={i} onClick={() => submit(opt)} disabled={answered !== null}
                  style={{ padding: "13px 16px", borderRadius: 10, background: bg, border: `1px solid ${border}`, color: col, textAlign: "left", cursor: answered !== null ? "default" : "pointer", fontSize: 14, transition: "all 0.2s" }}>
                  <span style={{ color: "#ffffff44", marginRight: 10 }}>{String.fromCharCode(65 + i)}.</span>{opt}
                </button>
              );
            })}
          </div>
        )}
      </div>
    </div>
  );
}

function ChatScreen({ state, setState }) {
  const user = state.users.find(u => u.id === state.currentUser);
  const partner = state.users.find(u => u.id !== state.currentUser);
  const [msg, setMsg] = useState("");
  const chatRef = useRef(null);

  useEffect(() => {
    if (chatRef.current) chatRef.current.scrollTop = chatRef.current.scrollHeight;
  }, [state.room.chat]);

  function sendMsg() {
    if (!msg.trim()) return;
    const now = new Date();
    const time = now.toLocaleTimeString("en", { hour: "2-digit", minute: "2-digit" });
    setState(s => ({
      ...s, room: {
        ...s.room,
        chat: [...s.room.chat, { from: s.currentUser, text: msg.trim(), time }]
      }
    }));
    setMsg("");
    // Simulate partner response
    const responses = [
      "That's a great word! 📚", "haha, true 😂", "Let's quiz after this 🔥",
      "Wait till you see tomorrow's words 👀", "I already knew that one 😤",
      "Adding to my notes rn ✍️", "GG", "Let's go!! 🚀"
    ];
    if (Math.random() > 0.4) {
      setTimeout(() => {
        const t2 = new Date().toLocaleTimeString("en", { hour: "2-digit", minute: "2-digit" });
        setState(s => ({
          ...s, room: {
            ...s.room,
            chat: [...s.room.chat, { from: partner.id, text: responses[Math.floor(Math.random() * responses.length)], time: t2 }]
          }
        }));
      }, 1500 + Math.random() * 2000);
    }
  }

  const chat = state.room.chat;

  return (
    <div style={{ height: "100vh", background: "#0a0a0f", fontFamily: "'Syne', sans-serif", color: "#fff", display: "flex", flexDirection: "column" }}>
      {/* Header */}
      <div style={{ padding: "16px 20px", borderBottom: "1px solid #ffffff10", display: "flex", alignItems: "center", gap: 12 }}>
        <button onClick={() => setState(s => ({ ...s, screen: "home" }))}
          style={{ background: "#ffffff10", border: "1px solid #ffffff20", color: "#fff", borderRadius: 8, padding: "8px 14px", cursor: "pointer" }}>
          ←
        </button>
        <Avatar name={partner.name} color={partner.color} size={36} />
        <div>
          <div style={{ fontWeight: 700 }}>{partner.name}</div>
          <div style={{ color: "#10b981", fontSize: 12 }}>● Online</div>
        </div>
      </div>

      {/* Messages */}
      <div ref={chatRef} style={{ flex: 1, overflowY: "auto", padding: 20, display: "flex", flexDirection: "column", gap: 12 }}>
        {chat.map((m, i) => {
          const isMe = m.from === state.currentUser;
          const sender = state.users.find(u => u.id === m.from);
          return (
            <div key={i} style={{ display: "flex", flexDirection: isMe ? "row-reverse" : "row", gap: 8, alignItems: "flex-end" }}>
              {!isMe && <Avatar name={sender?.name || "?"} color={sender?.color || "#666"} size={28} />}
              <div style={{ maxWidth: "75%" }}>
                <div style={{
                  background: isMe ? "linear-gradient(135deg, #6366f1, #8b5cf6)" : "#ffffff0f",
                  border: isMe ? "none" : "1px solid #ffffff12",
                  borderRadius: isMe ? "16px 16px 4px 16px" : "16px 16px 16px 4px",
                  padding: "10px 14px", fontSize: 14, lineHeight: 1.5,
                }}>
                  {m.text}
                </div>
                <div style={{ color: "#ffffff33", fontSize: 11, marginTop: 3, textAlign: isMe ? "right" : "left" }}>{m.time}</div>
              </div>
            </div>
          );
        })}
      </div>

      {/* Input */}
      <div style={{ padding: "12px 20px", borderTop: "1px solid #ffffff10", display: "flex", gap: 10 }}>
        <input value={msg} onChange={e => setMsg(e.target.value)}
          onKeyDown={e => e.key === "Enter" && sendMsg()}
          placeholder="Message..."
          style={{
            flex: 1, padding: "12px 16px", background: "#ffffff0c", border: "1px solid #ffffff20",
            borderRadius: 10, color: "#fff", fontSize: 14, outline: "none", fontFamily: "inherit",
          }}
        />
        <button onClick={sendMsg} style={{
          padding: "12px 20px", borderRadius: 10,
          background: "linear-gradient(135deg, #6366f1, #8b5cf6)",
          border: "none", color: "#fff", cursor: "pointer", fontSize: 18,
        }}>➤</button>
      </div>
    </div>
  );
}

function LeaderboardScreen({ state, setState }) {
  const room = state.room;
  const sorted = [...state.users].sort((a, b) => (room.weeklyPoints[b.id] || 0) - (room.weeklyPoints[a.id] || 0));
  const leader = sorted[0];

  return (
    <div style={{ minHeight: "100vh", background: "#0a0a0f", fontFamily: "'Syne', sans-serif", color: "#fff" }}>
      <div style={{ maxWidth: 600, margin: "0 auto", padding: 20 }}>
        <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 24 }}>
          <button onClick={() => setState(s => ({ ...s, screen: "home" }))}
            style={{ background: "#ffffff10", border: "1px solid #ffffff20", color: "#fff", borderRadius: 8, padding: "8px 14px", cursor: "pointer" }}>
            ← Back
          </button>
          <h2 style={{ margin: 0, fontSize: 20, fontWeight: 700 }}>Weekly Leaderboard 🏆</h2>
        </div>

        {/* Winner card */}
        <div style={{
          background: "linear-gradient(135deg, #f59e0b22, #a855f722)",
          border: "1px solid #f59e0b44", borderRadius: 20, padding: "24px",
          textAlign: "center", marginBottom: 20,
        }}>
          <div style={{ fontSize: 40 }}>👑</div>
          <Avatar name={leader.name} color={leader.color} size={56} />
          <div style={{ fontSize: 20, fontWeight: 800, marginTop: 8 }}>{leader.name}</div>
          <div style={{ fontSize: 36, fontWeight: 800, color: "#f59e0b" }}>{room.weeklyPoints[leader.id] || 0}</div>
          <div style={{ color: "#ffffff55", fontSize: 13 }}>points this week</div>
          <Badge text="Weekly Champion" color="#f59e0b" />
        </div>

        {/* Full ranking */}
        <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
          {sorted.map((u, i) => {
            const isMe = u.id === state.currentUser;
            const pts = room.weeklyPoints[u.id] || 0;
            const allTime = room.scores[u.id] || 0;
            const streak = room.streaks[u.id] || 0;
            return (
              <div key={u.id} style={{
                background: isMe ? "#6366f111" : "#ffffff08",
                border: `1px solid ${isMe ? "#6366f144" : "#ffffff12"}`,
                borderRadius: 14, padding: "16px 18px",
                display: "flex", alignItems: "center", gap: 14,
              }}>
                <div style={{ fontSize: 24, width: 32, textAlign: "center" }}>{i === 0 ? "🥇" : i === 1 ? "🥈" : "🥉"}</div>
                <Avatar name={u.name} color={u.color} size={40} />
                <div style={{ flex: 1 }}>
                  <div style={{ fontWeight: 700, fontSize: 16 }}>{u.name} {isMe && <span style={{ color: "#6366f1", fontSize: 12 }}>(you)</span>}</div>
                  <div style={{ color: "#ffffff55", fontSize: 12 }}>🔥 {streak} day streak · {allTime} all-time pts</div>
                </div>
                <div style={{ textAlign: "right" }}>
                  <div style={{ fontSize: 24, fontWeight: 800, color: u.color }}>{pts}</div>
                  <div style={{ color: "#ffffff44", fontSize: 11 }}>this week</div>
                </div>
              </div>
            );
          })}
        </div>

        {/* Stats comparison */}
        <div style={{ marginTop: 24 }}>
          <div style={{ color: "#ffffff55", fontSize: 11, textTransform: "uppercase", letterSpacing: "0.06em", marginBottom: 12 }}>Stats Comparison</div>
          <div style={{ background: "#ffffff08", border: "1px solid #ffffff12", borderRadius: 14, padding: 16 }}>
            <div style={{ display: "grid", gridTemplateColumns: "1fr auto 1fr", gap: 8, alignItems: "center" }}>
              {[
                { label: "Weekly Points", key: "weeklyPoints" },
                { label: "All-Time Score", key: "scores" },
                { label: "Day Streak", key: "streaks" },
              ].map(stat => {
                const u1 = state.users[0], u2 = state.users[1];
                const v1 = room[stat.key]?.[u1.id] || 0, v2 = room[stat.key]?.[u2.id] || 0;
                return (
                  <>
                    <div style={{ textAlign: "center" }}>
                      <div style={{ fontSize: 22, fontWeight: 800, color: u1.color }}>{v1}</div>
                    </div>
                    <div style={{ textAlign: "center", color: "#ffffff44", fontSize: 12 }}>{stat.label}</div>
                    <div style={{ textAlign: "center" }}>
                      <div style={{ fontSize: 22, fontWeight: 800, color: u2.color }}>{v2}</div>
                    </div>
                  </>
                );
              })}
            </div>
            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", marginTop: 12, gap: 8 }}>
              {state.users.map(u => (
                <div key={u.id} style={{ textAlign: "center", color: "#ffffff55", fontSize: 12 }}>{u.name}</div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}

// ─── APP ────────────────────────────────────────────────────────────────────
export default function App() {
  const [state, setStateRaw] = useState(() => {
    const saved = loadState();
    return saved || INITIAL_STATE;
  });

  const setState = useCallback((updater) => {
    setStateRaw(prev => {
      const next = typeof updater === "function" ? updater(prev) : updater;
      saveState(next);
      return next;
    });
  }, []);

  // Google Fonts
  useEffect(() => {
    const link = document.createElement("link");
    link.href = "https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&display=swap";
    link.rel = "stylesheet";
    document.head.appendChild(link);
  }, []);

  const screens = {
    login: <LoginScreen state={state} setState={setState} />,
    home: <HomeScreen state={state} setState={setState} />,
    daily: <DailyWordsScreen state={state} setState={setState} />,
    quiz: <QuizScreen state={state} setState={setState} />,
    mistakes: <MistakesScreen state={state} setState={setState} />,
    revision: <RevisionScreen state={state} setState={setState} />,
    chat: <ChatScreen state={state} setState={setState} />,
    leaderboard: <LeaderboardScreen state={state} setState={setState} />,
  };

  return (
    <div style={{ margin: 0, padding: 0 }}>
      {screens[state.screen] || screens.login}
    </div>
  );
}
