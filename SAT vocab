              <button key={w.word} onClick={() => setCurrentIdx(i)} style={{
                padding: "6px 14px", borderRadius: 99,
                background: i === currentIdx ? "#6366f133" : "#ffffff08",
                border: `1px solid ${i === currentIdx ? "#6366f166" : "#ffffff15"}`,
                color: learned[w.word] ? "#10b981" : i === currentIdx ? "#a5b4fc" : "#ffffff88",
                fontSize: 13, cursor: "pointer",
              }}>
                {learned[w.word] ? "✓ " : ""}{w.word}
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  );
}

function QuizScreen({ state, setState }) {
  const user = state.users.find(u => u.id === state.currentUser);
  const partner = state.users.find(u => u.id !== state.currentUser);
  const room = state.room;
  const [quizState, setQuizState] = useState("lobby"); // lobby | playing | results
  const [questions, setQuestions] = useState([]);
  const [qIdx, setQIdx] = useState(0);
  const [myScore, setMyScore] = useState(0);
  const [partnerScore, setPartnerScore] = useState(0);
  const [answered, setAnswered] = useState(null);
  const [fillInput, setFillInput] = useState("");
  const [showResult, setShowResult] = useState(false);
  const [timeLeft, setTimeLeft] = useState(15);
  const timerRef = useRef(null);

  function startQuiz() {
    const wordPool = getDailyWords(room.learnedWordIndices);
    const qs = wordPool.slice(0, 8).map(w => genQuizQuestion(w, SAT_WORDS));
    setQuestions(qs);
    setQIdx(0);
    setMyScore(0);
    setPartnerScore(0);
    setAnswered(null);
    setShowResult(false);
    setFillInput("");
    setTimeLeft(15);
    setQuizState("playing");
  }

  useEffect(() => {
    if (quizState !== "playing" || showResult) return;
    setTimeLeft(15);
    timerRef.current = setInterval(() => {
      setTimeLeft(t => {
        if (t <= 1) {
          clearInterval(timerRef.current);
          handleTimeout();
          return 0;
        }
        return t - 1;
      });
    }, 1000);
    return () => clearInterval(timerRef.current);
  }, [qIdx, quizState, showResult]);

  function handleTimeout() {
    if (answered !== null) return;
    setAnswered("__timeout__");
    setShowResult(true);
    const mis = questions[qIdx];
    const misIdx = SAT_WORDS.findIndex(w => w.word === mis.word.word);
    setState(s => ({
      ...s, room: {
        ...s.room,
        mistakes: [...s.room.mistakes.filter(m => m.word !== mis.word.word), { ...mis.word, index: misIdx }].slice(-50)
      }
    }));
    setTimeout(() => goNext(), 1800);
  }

  function submitAnswer(ans) {
    if (answered !== null) return;
    clearInterval(timerRef.current);
    const q = questions[qIdx];
    const correct = q.type === "fill"
      ? ans.trim().toLowerCase() === q.answer.toLowerCase()
      : ans === q.answer;
    setAnswered(ans);
    setShowResult(true);
    if (correct) {
      setMyScore(s => s + 1);
      setState(s => ({
        ...s,
        room: {
          ...s.room,
          scores: { ...s.room.scores, [s.currentUser]: (s.room.scores[s.currentUser] || 0) + 1 },
          weeklyPoints: { ...s.room.weeklyPoints, [s.currentUser]: (s.room.weeklyPoints[s.currentUser] || 0) + 1 },
        }
      }));
    } else {
      const misIdx = SAT_WORDS.findIndex(w => w.word === q.word.word);
      setState(s => ({
        ...s, room: {
          ...s.room,
          mistakes: [...s.room.mistakes.filter(m => m.word !== q.word.word), { ...q.word, index: misIdx }].slice(-50)
        }
      }));
    }
    // Simulate partner answering
    const partnerCorrect = Math.random() > 0.45;
    if (partnerCorrect) setPartnerScore(s => s + 1);
    setTimeout(() => goNext(), 1800);
  }

  function goNext() {
    if (qIdx >= questions.length - 1) {
      setQuizState("results");
    } else {
      setQIdx(i => i + 1);
      setAnswered(null);
      setShowResult(false);
      setFillInput("");
    }
  }

  if (quizState === "lobby") return (
    <div style={{ minHeight: "100vh", background: "#0a0a0f", fontFamily: "'Syne', sans-serif", color: "#fff" }}>
      <div style={{ maxWidth: 600, margin: "0 auto", padding: 20 }}>
        <button onClick={() => setState(s => ({ ...s, screen: "home" }))}
          style={{ background: "#ffffff10", border: "1px solid #ffffff20", color: "#fff", borderRadius: 8, padding: "8px 14px", cursor: "pointer", marginBottom: 24 }}>
          ← Back
        </button>
        <div style={{ textAlign: "center", padding: "40px 0" }}>
          <div style={{ fontSize: 64, marginBottom: 16 }}>⚡</div>
          <h2 style={{ fontSize: 28, fontWeight: 800, margin: "0 0 8px" }}>Quiz Battle</h2>
          <p style={{ color: "#ffffff66", marginBottom: 32 }}>8 questions · 15 seconds each · Live scoring</p>
          <div style={{ display: "flex", justifyContent: "center", gap: 20, marginBottom: 32 }}>
            <div style={{ textAlign: "center" }}>
              <Avatar name={user.name} color={user.color} size={48} />
              <div style={{ fontSize: 13, marginTop: 6 }}>{user.name}</div>
            </div>
            <div style={{ display: "flex", alignItems: "center", fontSize: 24 }}>⚔️</div>
            <div style={{ textAlign: "center" }}>
              <Avatar name={partner.name} color={partner.color} size={48} />
              <div style={{ fontSize: 13, marginTop: 6 }}>{partner.name}</div>
            </div>
          </div>
          <button onClick={startQuiz} style={{
            padding: "16px 48px", borderRadius: 12,
            background: "linear-gradient(135deg, #ec4899, #a855f7)",
            border: "none", color: "#fff", fontSize: 18, fontWeight: 800,
            cursor: "pointer", letterSpacing: "0.02em",
          }}>
            Start Battle!
          </button>
        </div>
      </div>
    </div>
  );

  if (quizState === "results") return (
    <div style={{ minHeight: "100vh", background: "#0a0a0f", fontFamily: "'Syne', sans-serif", color: "#fff" }}>
      <div style={{ maxWidth: 600, margin: "0 auto", padding: 20, textAlign: "center" }}>
        <div style={{ fontSize: 64, marginTop: 40 }}>{myScore > partnerScore ? "🏆" : myScore < partnerScore ? "😤" : "🤝"}</div>
        <h2 style={{ fontSize: 28, fontWeight: 800, marginBottom: 8 }}>
          {myScore > partnerScore ? "You Won!" : myScore < partnerScore ? `${partner.name} Won!` : "It's a Tie!"}
        </h2>
        <div style={{ display: "flex", justifyContent: "center", gap: 24, margin: "32px 0" }}>
          {[
            { name: user.name, score: myScore, color: user.color },
            { name: partner.name, score: partnerScore, color: partner.color },
          ].map((p, i) => (
            <div key={i} style={{ background: "#ffffff08", border: `1px solid ${p.color}44`, borderRadius: 16, padding: "20px 32px" }}>
              <div style={{ color: "#ffffff88", fontSize: 13, marginBottom: 4 }}>{p.name}</div>
              <div style={{ fontSize: 36, fontWeight: 800, color: p.color }}>{p.score}</div>
              <div style={{ color: "#ffffff55", fontSize: 12 }}>/ {questions.length}</div>
            </div>
          ))}
        </div>
        <div style={{ display: "flex", gap: 12, justifyContent: "center" }}>
          <button onClick={startQuiz} style={{ padding: "12px 32px", borderRadius: 10, background: "linear-gradient(135deg, #ec4899, #a855f7)", border: "none", color: "#fff", fontWeight: 700, cursor: "pointer", fontFamily: "inherit", fontSize: 15 }}>
            Rematch ⚡
          </button>
          <button onClick={() => setState(s => ({ ...s, screen: "home" }))} style={{ padding: "12px 32px", borderRadius: 10, background: "#ffffff10", border: "1px solid #ffffff20", color: "#fff", cursor: "pointer", fontFamily: "inherit", fontSize: 15 }}>
            Home
          </button>
        </div>
      </div>
    </div>
  );

  const q = questions[qIdx];
  const timerPct = (timeLeft / 15) * 100;
  const timerColor = timeLeft > 8 ? "#10b981" : timeLeft > 4 ? "#f59e0b" : "#ef4444";

  return (
    <div style={{ minHeight: "100vh", background: "#0a0a0f", fontFamily: "'Syne', sans-serif", color: "#fff" }}>
      <div style={{ maxWidth: 600, margin: "0 auto", padding: 20 }}>
        {/* Scoreboard */}
        <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 20 }}>
          <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
            <Avatar name={user.name} color={user.color} size={28} />
            <span style={{ fontSize: 20, fontWeight: 800, color: user.color }}>{myScore}</span>
          </div>
          <div style={{ textAlign: "center" }}>
            <div style={{ fontSize: 12, color: "#ffffff55" }}>Q {qIdx + 1}/{questions.length}</div>
            <div style={{ fontSize: 24, fontWeight: 800, color: timerColor }}>{timeLeft}s</div>
          </div>
          <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
            <span style={{ fontSize: 20, fontWeight: 800, color: partner.color }}>{partnerScore}</span>
            <Avatar name={partner.name} color={partner.color} size={28} />
          </div>
        </div>

        {/* Timer bar */}
        <div style={{ background: "#ffffff10", borderRadius: 99, height: 4, marginBottom: 20, overflow: "hidden" }}>
          <div style={{ height: "100%", width: `${timerPct}%`, background: timerColor, borderRadius: 99, transition: "width 1s linear, background 0.3s" }} />
        </div>

        {/* Question */}
        <div style={{ background: "#ffffff08", border: "1px solid #ffffff15", borderRadius: 16, padding: 24, marginBottom: 20 }}>
          <Badge text={q.type === "mcq" ? "Multiple Choice" : q.type === "fill" ? "Fill in Blank" : "Word Usage"} color="#ec4899" />
          <div style={{ fontSize: 18, fontWeight: 600, marginTop: 14, lineHeight: 1.5, whiteSpace: "pre-wrap" }}>
            {q.prompt}
          </div>
        </div>

        {/* Answer input */}
        {q.type === "fill" ? (
          <div>
            <input
              value={fillInput} onChange={e => setFillInput(e.target.value)}
              onKeyDown={e => e.key === "Enter" && submitAnswer(fillInput)}
              disabled={answered !== null}
              placeholder="Type your answer..."
              style={{
                width: "100%", padding: "14px 16px", background: "#ffffff0c",
                border: "1px solid #ffffff25", borderRadius: 10, color: "#fff",
                fontSize: 16, marginBottom: 10, outline: "none", boxSizing: "border-box",
                fontFamily: "inherit",
              }}
            />
            {answered === null && (
              <button onClick={() => submitAnswer(fillInput)} style={{
                width: "100%", padding: "13px", borderRadius: 10,
                background: "linear-gradient(135deg, #ec4899, #a855f7)",
                border: "none", color: "#fff", fontWeight: 700, cursor: "pointer", fontSize: 15,
              }}>Submit</button>
            )}
          </div>
        ) : (
          <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
            {q.options.map((opt, i) => {
              let bg = "#ffffff08", border = "#ffffff15", col = "#fff";
              if (showResult) {
                if (opt === q.answer) { bg = "#10b98122"; border = "#10b98155"; col = "#34d399"; }
                else if (opt === answered) { bg = "#ef444422"; border = "#ef444455"; col = "#f87171"; }
              }
              return (
                <button key={i} onClick={() => submitAnswer(opt)} disabled={answered !== null}
                  style={{
                    padding: "14px 18px", borderRadius: 10, background: bg,
                    border: `1px solid ${border}`, color: col, textAlign: "left",
                    cursor: answered !== null ? "default" : "pointer", fontSize: 14,
                    transition: "all 0.2s",
                  }}>
                  <span style={{ color: "#ffffff44", marginRight: 10 }}>{String.fromCharCode(65 + i)}.</span>
                  {opt}
                </button>
              );
            })}
          </div>
        )}

        {showResult && answered === "__timeout__" && (
          <div style={{ background: "#f59e0b22", border: "1px solid #f59e0b44", borderRadius: 10, padding: "12px 16px", marginTop: 10, color: "#fbbf24" }}>
            ⏰ Time's up! The answer was: <strong>{q.answer}</strong>
          </div>
        )}
      </div>
    </div>
  );
}

