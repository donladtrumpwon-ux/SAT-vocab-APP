function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function getDayIndex() {
  const start = new Date("2024-01-01");
  const now = new Date();
  return Math.floor((now - start) / (1000 * 60 * 60 * 24));
}

function getDailyWords(learnedIndices = []) {
  const dayIdx = getDayIndex();
  const available = SAT_WORDS.filter((_, i) => !learnedIndices.includes(i));
  const seed = dayIdx * 12;
  const slice = [];
  for (let i = 0; i < 12 && i < available.length; i++) {
    slice.push(available[(seed + i * 7) % available.length]);
  }
  return slice;
}

function speak(word) {
  if ("speechSynthesis" in window) {
    const u = new SpeechSynthesisUtterance(word);
    u.lang = "en-US";
    window.speechSynthesis.cancel();
    window.speechSynthesis.speak(u);
  }
}

function genQuizQuestion(word, allWords) {
  const types = ["mcq", "fill", "sentence"];
  const type = types[Math.floor(Math.random() * types.length)];
  const distractors = shuffle(allWords.filter(w => w.word !== word.word)).slice(0, 3);

  if (type === "mcq") {
    const options = shuffle([word, ...distractors]);
    return {
      type: "mcq",
      prompt: `What is the meaning of "${word.word}"?`,
      word,
      options: options.map(o => o.meaning),
      answer: word.meaning,
    };
  } else if (type === "fill") {
    const blanked = word.example.replace(new RegExp(word.word, "gi"), "_____");
    return {
      type: "fill",
      prompt: `Fill in the blank: "${blanked}"`,
      word,
      answer: word.word.toLowerCase(),
    };
  } else {
    const options = shuffle([word, ...distractors]);
    return {
      type: "sentence",
      prompt: `Which word fits best in this sentence?\n"${word.example.replace(new RegExp(word.word, "gi"), "_____")}"`,
      word,
      options: options.map(o => o.word),
      answer: word.word,
    };
  }
}

